generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tables better-auth : présentes en base pour que `prisma db push` / migrate ne les suppriment pas.
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  ruggers            Rugger[]
  fundingChainCache  FundingChainCache[]
  watchlistWallets   WatchlistWallet[]
  notifications      Notification[]
  walletMetadata     WalletMetadata[]
  pnlWallets         PnlWallet[]
  pnlBackgrounds     PnlBackground[]

  @@unique([email])
  @@map("user")
}

model WalletMetadata {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String   @map("wallet_address")
  createdAt     DateTime? @map("created_at")
  creationSource String   @default("helius_first_tx") @map("creation_source")
  lastFetchedAt DateTime @default(now()) @map("last_fetched_at")
  insertedAt    DateTime @default(now()) @map("inserted_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  @@unique([userId, walletAddress])
  @@index([userId])
  @@map("wallet_metadata")
}

model PnlWallet {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String   @map("wallet_address")
  label         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  @@unique([userId, walletAddress])
  @@index([userId])
  @@map("pnl_wallets")
}

model PnlBackground {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String?
  imageData  String   @map("image_data")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@index([userId])
  @@map("pnl_backgrounds")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Status {
  id      String        @id
  label   String
  order   Int           @unique
  ruggers Rugger[]
  tokens  RuggerToken[]

  @@map("statuses")
}

model Rugger {
  id            String        @id @default(dbgenerated("gen_random_uuid()"))
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String?
  description   String?       @map("description")
  walletAddress String?       @map("wallet_address")
  walletType    String        @map("wallet_type")
  volumeMin     Float?        @map("volume_min")
  volumeMax     Float?        @map("volume_max")
  startHour     Int?          @map("start_hour")
  endHour       Int?          @map("end_hour")
  notes         String?       @map("notes")
  statusId      String        @default("verification") @map("status_id")
  status        Status        @relation(fields: [statusId], references: [id])
  archived      Boolean       @default(false) @map("archived")
  createdAt     DateTime      @default(now()) @map("created_at")
  tokens        RuggerToken[]
  analyses      WalletAnalysis[]
  buyerWallets  RuggerBuyerWallet[]

  @@unique([userId, walletAddress])
  @@index([userId])
  @@map("ruggers")
}

model RuggerBuyerWallet {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  ruggerId      String   @map("rugger_id")
  rugger        Rugger   @relation(fields: [ruggerId], references: [id], onDelete: Cascade)
  walletAddress String   @map("wallet_address")
  label         String?
  notes         String?
  origin        String   @default("manual")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  @@unique([ruggerId, walletAddress])
  @@index([ruggerId])
  @@index([walletAddress])
  @@map("rugger_buyer_wallets")
}

model RuggerToken {
  id                String    @id @default(dbgenerated("gen_random_uuid()"))
  rugger            Rugger    @relation(fields: [ruggerId], references: [id], onDelete: Cascade)
  ruggerId          String    @map("rugger_id")
  name              String
  entryMcap         Float?    @map("entry_mcap")
  entryPrice        Float     @map("entry_price")
  high              Float
  low               Float
  targetExitPercent Float     @map("target_exit_percent")
  statusId          String    @default("verification") @map("status_id")
  status            Status    @relation(fields: [statusId], references: [id])
  createdAt         DateTime  @default(now()) @map("created_at")
  purchasedAt       DateTime? @map("purchased_at")
  tokenAddress      String?   @map("token_address")
  /** Libellé / symbole affiché ; `name` conserve l’identifiant mint (adresse). */
  tokenName         String?   @map("token_name")

  @@index([ruggerId, createdAt])
  @@index([ruggerId, purchasedAt])
  @@map("rugger_tokens")
}

// ---------------------------------------------------------------------------
// Wallet Network Analysis
// ---------------------------------------------------------------------------

model WalletAnalysis {
  id            String    @id @default(dbgenerated("gen_random_uuid()"))
  ruggerId      String    @map("rugger_id")
  rugger        Rugger    @relation(fields: [ruggerId], references: [id], onDelete: Cascade)
  mode          String    @default("combined") // token | funding | combined
  status        String    @default("pending")
  fundingDepth  Int       @default(5) @map("funding_depth")
  buyerLimit    Int       @default(200) @map("buyer_limit")
  tokenCount    Int       @default(0) @map("token_count")
  buyerCount    Int       @default(0) @map("buyer_count")
  progress      Int       @default(0)
  progressLabel String?   @map("progress_label")
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  buyerWallets    AnalysisBuyerWallet[]
  motherAddresses AnalysisMotherAddress[]

  @@index([ruggerId])
  @@map("wallet_analyses")
}

model AnalysisBuyerWallet {
  id              String    @id @default(dbgenerated("gen_random_uuid()"))
  analysisId      String    @map("analysis_id")
  analysis        WalletAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  walletAddress   String    @map("wallet_address")
  source          String    @default("token") // token | funding | both
  motherAddressId String?   @map("mother_address_id")
  motherAddress   AnalysisMotherAddress? @relation(fields: [motherAddressId], references: [id])
  tokensBought    Int       @default(0) @map("tokens_bought")
  totalTokens     Int       @default(0) @map("total_tokens")
  coveragePercent Float     @default(0) @map("coverage_percent")
  firstBuyAt      DateTime? @map("first_buy_at")
  lastBuyAt       DateTime? @map("last_buy_at")
  activeDays      Int       @default(0) @map("active_days")
  spanDaysInScope Float     @default(0) @map("span_days_in_scope")
  consistency     Float     @default(0)
  weight          Float     @default(0)
  avgHoldDuration Float?    @map("avg_hold_duration_hours")
  fundingDepth    Int?      @map("funding_depth")
  fundingChain    String?   @map("funding_chain")
  motherChildCount Int      @default(0) @map("mother_child_count")
  hasHighFanoutMother Boolean @default(false) @map("has_high_fanout_mother")
  matchingConfidence Float   @default(0) @map("matching_confidence")
  inclusionDecision String   @default("included") @map("inclusion_decision")
  riskFlag         String?   @map("risk_flag")
  riskLevel        String?   @map("risk_level")
  decisionReasons  Json      @default("[]") @map("decision_reasons")

  purchases AnalysisBuyerPurchase[]

  @@unique([analysisId, walletAddress])
  @@index([analysisId])
  @@map("analysis_buyer_wallets")
}

model AnalysisBuyerPurchase {
  id            String    @id @default(dbgenerated("gen_random_uuid()"))
  buyerWalletId String    @map("buyer_wallet_id")
  buyerWallet   AnalysisBuyerWallet @relation(fields: [buyerWalletId], references: [id], onDelete: Cascade)
  tokenAddress  String    @map("token_address")
  tokenName     String?   @map("token_name")
  purchasedAt   DateTime? @map("purchased_at")
  amountSol     Float?    @map("amount_sol")

  @@unique([buyerWalletId, tokenAddress])
  @@index([buyerWalletId])
  @@map("analysis_buyer_purchases")
}

model AnalysisMotherAddress {
  id            String    @id @default(dbgenerated("gen_random_uuid()"))
  analysisId    String    @map("analysis_id")
  analysis      WalletAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  address       String
  walletsFunded Int       @default(0) @map("wallets_funded")
  validated     Boolean   @default(false)
  validatedAt   DateTime? @map("validated_at")

  buyerWallets AnalysisBuyerWallet[]

  @@unique([analysisId, address])
  @@index([analysisId])
  @@map("analysis_mother_addresses")
}

model FundingChainCache {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String   @map("wallet_address")
  motherAddress String?  @map("mother_address")
  fundingDepth  Int      @map("funding_depth")
  chainJson     String   @map("chain_json")
  resolvedAt    DateTime @default(now()) @map("resolved_at")

  @@unique([userId, walletAddress])
  @@index([userId])
  @@map("funding_chain_cache")
}

model WatchlistWallet {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress  String   @map("wallet_address")
  label          String?
  notes          String?
  sourceRuggerId String?  @map("source_rugger_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([userId, walletAddress])
  @@index([userId])
  @@map("watchlist_wallets")
}

model Notification {
  id             String    @id @default(dbgenerated("gen_random_uuid()"))
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String    @default("watchlist_buy")
  walletAddress  String    @map("wallet_address")
  walletLabel    String?   @map("wallet_label")
  tokenAddress   String?   @map("token_address")
  tokenSymbol    String?   @map("token_symbol")
  amountSol      Decimal?  @map("amount_sol") @db.Decimal(18, 9)
  txSignature    String    @map("tx_signature")
  occurredAt     DateTime  @map("occurred_at")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([userId, walletAddress, txSignature])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model HeliusWebhookSync {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  webhookId    String   @unique @map("webhook_id")
  lastSyncedAt DateTime @default(now()) @map("last_synced_at")
  addressCount Int      @default(0) @map("address_count")

  @@map("helius_webhook_sync")
}
