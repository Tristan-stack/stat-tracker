generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tables better-auth : présentes en base pour que `prisma db push` / migrate ne les suppriment pas.
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  ruggers       Rugger[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Status {
  id      String        @id
  label   String
  order   Int           @unique
  ruggers Rugger[]
  tokens  RuggerToken[]

  @@map("statuses")
}

model Rugger {
  id            String        @id @default(dbgenerated("gen_random_uuid()"))
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String?
  description   String?       @map("description")
  walletAddress String        @map("wallet_address")
  walletType    String        @map("wallet_type")
  volumeMin     Float?        @map("volume_min")
  volumeMax     Float?        @map("volume_max")
  startHour     Int?          @map("start_hour")
  endHour       Int?          @map("end_hour")
  notes         String?       @map("notes")
  statusId      String        @default("verification") @map("status_id")
  status        Status        @relation(fields: [statusId], references: [id])
  archived      Boolean       @default(false) @map("archived")
  createdAt     DateTime      @default(now()) @map("created_at")
  tokens        RuggerToken[]

  @@unique([userId, walletAddress])
  @@index([userId])
  @@map("ruggers")
}

model RuggerToken {
  id                String   @id @default(dbgenerated("gen_random_uuid()"))
  rugger            Rugger   @relation(fields: [ruggerId], references: [id], onDelete: Cascade)
  ruggerId          String   @map("rugger_id")
  name              String
  entryMcap         Float?   @map("entry_mcap")
  entryPrice        Float    @map("entry_price")
  high              Float
  low               Float
  targetExitPercent Float    @map("target_exit_percent")
  statusId          String   @default("verification") @map("status_id")
  status            Status   @relation(fields: [statusId], references: [id])
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([ruggerId, createdAt])
  @@map("rugger_tokens")
}
