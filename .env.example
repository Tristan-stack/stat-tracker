# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth
BETTER_AUTH_URL=http://localhost:3000

# GMGN
GMGN_API_KEY=
GMGN_HOST=

# Helius (Solana)
HELIUS_API_KEY=
HELIUS_RPS=2                # Conservative default to avoid 429 on strict plans
HELIUS_MAX_RETRIES=3
HELIUS_RETRY_BASE_MS=300
HELIUS_RATE_LIMIT_MIN_WAIT_MS=2000
HELIUS_RATE_LIMIT_MAX_WAIT_MS=10000
HELIUS_PARSE_BATCH_SIZE=50  # Lower batch reduces burst pressure on /v0/transactions

# Analysis
ANALYSIS_CONCURRENCY=3      # Parallel tokens during buyer discovery
