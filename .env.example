# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth
BETTER_AUTH_URL=http://localhost:3000

# GMGN
GMGN_API_KEY=
GMGN_HOST=

# Helius (Solana)
HELIUS_API_KEY=
HELIUS_RPS=2                # Conservative default to avoid 429 on strict plans
HELIUS_MAX_RETRIES=3
HELIUS_RETRY_BASE_MS=300
HELIUS_RATE_LIMIT_MIN_WAIT_MS=2000
HELIUS_RATE_LIMIT_MAX_WAIT_MS=10000
HELIUS_PARSE_BATCH_SIZE=50  # Lower batch reduces burst pressure on /v0/transactions

# Analysis
ANALYSIS_CONCURRENCY=3      # Parallel tokens during buyer discovery
FILTER_ACTIVE_CONCURRENCY=10  # Parallel Helius calls used by the "exclude inactive > 24h" filter
BEST_WALLET_TIE_MAX=120     # Max wallets analyzed in "best wallet" when many tie on top analysis coverage (override with ?maxTieWallets=)

# Helius Webhooks (watchlist notifications)
APP_URL=http://localhost:3000              # Public base URL; required to register the webhook callback
HELIUS_WEBHOOK_SECRET=change-me-long-random # Shared secret sent in the Authorization header
